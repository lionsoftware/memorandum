{
  "name": "memorandum-mcp",
  "version": "0.1.0",
  "description": "MCP server with memory: facts (short records with LRU expiration) and documents (with metadata and semantic search)",
  "author": "lionsoftware <33127234+lionsoftware@users.noreply.github.com>",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/lionsoftware/memorandum.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "memorandum": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "memory",
    "semantic-search"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "lru-cache": "^11.2.7",
    "pino": "^10.3.1",
    "safe-regex2": "^5.1.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
